void boton1() {
  if (estado=="nav 1/4" || estado=="nav 2/4" || estado=="nav 3/4"|| estado=="nav 4/4"|| estado=="pasc 1/4"|| estado=="pasc 2/4"|| estado=="pasc 3/4"|| estado=="pasc 4/4" || estado=="jacknoel"||estado=="jackconejo"){
    fill(0);
    strokeWeight(3);
    stroke(#E4E825);
    rect(70, 515, 135, 50);
  }
}

