void PuertaNavidad(){
 if (mouseX>0 && mouseX<width-width/2 && mouseY>0 && mouseY<height && estado == "puertas"){
 fill(0,255,0,100);
 rect(0,0,width-width/2,height);
 }
}

void PuertaPascuas(){
  if (mouseX>400 && mouseX<800 && mouseY>0 && mouseY<height){
 fill(255,0,0,100);
 rect(400,0,400,height);
 }
}
